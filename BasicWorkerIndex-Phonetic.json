  "scoringProfiles": [
    {
      "name": "boostFirstName",
      "functionAggregation": "sum",
      "text": {
        "weights": {
          "DisplayName": 5,
          "FirstName": 4,
          "LastName": 3,
          "FirstName_phonetic": 2,
          "LastName_phonetic": 2
        }
      },
      "functions": []
    }
  ],
  "suggesters": [
    {
      "name": "employee-suggester",
      "searchMode": "analyzingInfixMatching",
      "sourceFields": [
        "DisplayName",
        "FirstName",
        "LastName",
        "Title",
        "Department"
      ]
    }
  ],
  "analyzers": [
    {
      "name": "phonetic_analyzer",
      "@odata.type": "#Microsoft.Azure.Search.CustomAnalyzer",
      "tokenizer": "standard_v2",
      "tokenFilters": [
        "lowercase",
        "phonetic_filter"
      ]
    }
  ],
  "tokenFilters": [
    {
      "name": "phonetic_filter",
      "@odata.type": "#Microsoft.Azure.Search.PhoneticTokenFilter",
      "encoder": "doubleMetaphone"
    }
  ],
  "corsOptions": {
    "allowedOrigins": [
      "*"
    ]
  }
}
